{
  "name": "vaultmind",
  "version": "0.4.1",
  "description": "Your personal AI. Local. Private. Yours.",
  "main": "main.js",
  "scripts": {
    "start":     "electron .",
    "build:mac": "electron-builder --mac --publish never",
    "build:win": "electron-builder --win --publish never",
    "build":     "electron-builder --mac --publish never",
    "pack":      "electron-builder --dir"
  },
  "devDependencies": {
    "electron":         "^34.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId":       "com.vaultmind.app",
    "productName": "VaultMind",
    "copyright":   "Copyright © 2025 VaultMind",
    "asar": false,

    "mac": {
      "category":     "public.app-category.productivity",
      "artifactName": "VaultMind-mac.${ext}",
      "target": [
        { "target": "dmg", "arch": ["universal"] }
      ]
    },

    "dmg": {
      "title":           "Install VaultMind",
      "backgroundColor": "#0f0f0f",
      "window":          { "width": 540, "height": 380 }
    },

    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },

    "nsis": {
      "artifactName":                        "VaultMind-Setup.${ext}",
      "oneClick":                            false,
      "allowToChangeInstallationDirectory":  true,
      "createDesktopShortcut":               true,
      "createStartMenuShortcut":             true,
      "shortcutName":                        "VaultMind"
    },

    "files": [
      "main.js",
      "package.json",
      "backend/**/*",
      "frontend/**/*",
      "!backend/__pycache__/**",
      "!backend/**/*.pyc",
      "!backend/chroma_db/**",
      "!backend/connector_config.json",
      "!backend/feed_events.json",
      "!backend/gmail_token.json",
      "!backend/gmail_credentials.json",
      "!**/*.log"
    ]
  }
}
